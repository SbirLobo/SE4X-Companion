msgid "<60"
msgstr ""

#: app/data/solo_scenario_book.py:3899 app/data/solo_scenario_book.py:3940
#: app/data/solo_scenario_book.py:3947 app/data/solo_scenario_book.py:3960
#: app/data/solo_scenario_book.py:3967
msgid "60-120"
msgstr ""

