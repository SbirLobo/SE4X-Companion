#: app/data/solo_scenario_book.py:3949 app/data/solo_scenario_book.py:3963
#: app/data/solo_scenario_book.py:3969
msgid ">300"
msgstr ""

#: app/data/solo_scenario_book.py:3917
msgid "Known AP Fleet SCT Ship and Fighter"
msgstr ""

#: app/data/solo_scenario_book.py:3919
msgid "Restock"
msgstr ""

#: app/data/solo_scenario_book.py:3920
msgid ""
