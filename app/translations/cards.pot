msgstr ""

#: app/data/cards.py:10
msgid "SC and DD pay 1/2 maintenance (round down the total)."
msgstr ""

#: app/data/cards.py:12 app/data/cards.py:36 app/data/cards.py:52
#: app/data/cards.py:60 app/data/cards.py:70 app/data/cards.py:78
